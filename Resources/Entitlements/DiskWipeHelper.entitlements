<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
        ==================================================================
        DiskWipeHelper — SMAppService privileged daemon entitlements
        ==================================================================
        The helper is the ONLY component that runs as root. It exposes an
        XPC interface to the GUI; every command is authorised through
        macOS Authorization Services (Touch ID / password). NOPASSWD
        sudoers grant is deleted on first launch of v1.0.
    -->

    <!-- Required for any privileged helper executed by launchd as root. -->
    <key>com.apple.security.app-sandbox</key>
    <false/>

    <!--
        NOTE: there is NO `com.apple.security.application-identifier` here
        on purpose. That key is iOS / sandboxed-app only; on macOS Developer
        ID it has no enforcement effect, so including it would falsely
        suggest a check that doesn't happen. The actual client-binding
        guarantee comes from:
          (a) the LaunchDaemons plist's MachServices dict (registers the
              global name `org.officesentinel.disk-manager.helper`)
          (b) the helper's `shouldAcceptNewConnection` method, which
              validates the caller's *audit token* against the GUI's
              Designated Requirement string. See XPC_HELPER_DESIGN.md §6.
    -->
    <!-- Helper itself signs as `org.officesentinel.disk-manager.helper`
         via the codesign --identifier flag in Scripts/notarize/sign.sh. -->

    <!-- Hardened-runtime hardening. -->
    <key>com.apple.security.cs.allow-jit</key>
    <false/>
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <false/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <false/>
    <key>com.apple.security.cs.disable-executable-page-protection</key>
    <false/>
</dict>
</plist>
